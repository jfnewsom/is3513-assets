      "code_block": "kali-lastname-studentID",
      "tip": "<strong style=\"color:#ffffff;\">Example:</strong> <code style=\"background:#1a1f2e;padding:2px 8px;border-radius:4px;font-family:Consolas,monospace;font-size:13px;color:#00D26A;\">kali-smith-abc123</code>"
    },
